# Database — Supabase Transaction pooler (port 6543) works from most home networks.
# Put in .env.local. Prisma CLI: `npm run db:push` (loads .env.local).
# Required for Supabase pooler: include pgbouncer=true (the app also appends it if missing).
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# Prisma migrate / db push (must NOT use transaction pooler 6543). Use Supavisor SESSION mode on the SAME pooler host as DATABASE_URL, port 5432.
# Supabase Dashboard → Connect → "Session pooler" (URI ends in :5432, host is *.pooler.supabase.com — NOT db.*.supabase.co).
# The db.*.supabase.co "direct" URL often fails from home networks (P1001); session pooler usually works.
# Match REGION and PROJECT_REF to your transaction URL; user is often postgres.PROJECT_REF.
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require"

# Optional: add &connect_timeout=30 if connections are slow (see Supabase Prisma troubleshooting).

# If both pooler URLs fail, run prisma/supabase-init.sql in Supabase → SQL Editor instead of db push.
# After pulling schema changes: `npm run db:push` (or run prisma/supabase-add-requires-email-verification.sql in Supabase).

# Auth.js / NextAuth — use one secret (both names supported in this app)
AUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_SECRET="same-as-AUTH_SECRET-if-using-legacy-name"
# Must match where you run the app (port included). Reset emails use NEXT_PUBLIC_APP_URL first, then this.
# Production: use a full URL with scheme, e.g. https://www.readmypay.com — bare hostnames (www.example.com) break Stripe and some libraries; the app patches these on the server when possible.
NEXTAUTH_URL="http://localhost:3000"
# Same origin as NEXTAUTH_URL while developing. Emails contain this host — localhost only works in a browser on THIS computer; on a phone use the URL printed in the terminal when you request a reset, or use ngrok and set both to the tunnel URL.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Optional: force printing reset links to the server console (e.g. if app URL is not localhost but you still want logs)
# READ_MY_PAY_LOG_RESET_LINK="true"

# OpenAI — enable Zero Data Retention in OpenAI dashboard
OPENAI_API_KEY="sk-..."

# Local testing only: bypass per-month document counter (free tier = 1/mo in the database).
# Does not affect OpenAI API billing—you still need a valid API key and credits there.
READMY_PAY_DISABLE_USAGE_LIMIT="false"
# Legacy alias (still honored in code): FINCLEAR_DISABLE_USAGE_LIMIT="false"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_PERSONAL="price_..."
STRIPE_PRICE_PER_DOCUMENT="price_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Monthly plan ($9.99) — must match STRIPE_PRICE_PERSONAL. After changing, run `npm run build` again (inlined at build time).
NEXT_PUBLIC_STRIPE_PRICE_PERSONAL="price_..."
# One-time $0.99 per extra document (Checkout mode=payment). Must match STRIPE_PRICE_PER_DOCUMENT.
NEXT_PUBLIC_STRIPE_PRICE_PER_DOCUMENT="price_..."
# Stripe Dashboard → Settings → Customer portal — enable so “Manage billing & cancel” works.

# Optional: Google OAuth (set server IDs + flip client flag)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED="false"

# Resend — required for signup verification, forgot password, and the signed-in Support contact form (except local opt-in below).
# From address is fixed in code: lib/transactional-email-from.ts (support@readmypay.com); contact mail is also delivered to that address.
RESEND_API_KEY="re_..."
# Local only: allow signup to succeed without sending email (link printed in terminal). Not for production.
# READMY_PAY_DEV_SKIP_EMAIL="true"
# If mail never arrives: Resend → Domains (readmypay.com + support@), Resend → Logs, recipient spam folder.
# Temporarily log the verification link in server logs (Vercel → Functions): READ_MY_PAY_LOG_VERIFICATION_LINK="true"

# Production: your real HTTPS domain (also set on Vercel). For local dev, see NEXT_PUBLIC_APP_URL above.
# NEXT_PUBLIC_APP_URL="https://yourdomain.com"

# Vercel Cron — protect /api/cron/reset-usage
CRON_SECRET="long-random-string"

# --- Security (Vercel / production) ---
# Upstash Redis — required on Vercel production for IP rate limits (register, login, forgot password, resend verification).
# Create a Redis database at https://upstash.com and paste REST URL + token. Never prefix with NEXT_PUBLIC_.
UPSTASH_REDIS_REST_URL="https://....upstash.io"
UPSTASH_REDIS_REST_TOKEN="..."

# Cloudflare Turnstile — bot protection on signup, login, forgot password, resend verification.
# Dashboard: https://developers.cloudflare.com/turnstile/ — site key is safe in the browser; secret is server-only.
# Add every host you use (e.g. localhost, www.yourdomain.com, yourdomain.com) under the widget’s hostnames.
TURNSTILE_SECRET_KEY="0x4AAAA..."
NEXT_PUBLIC_TURNSTILE_SITE_KEY="0x4AAAA..."
# Local only: if challenges.cloudflare.com is blocked (npm start / strict network), set true so sign-in is not gated on the widget. Never set on Vercel production.
# NEXT_PUBLIC_TURNSTILE_BYPASS_LOCAL="true"

# Comma-separated. Only these emails can access /admin and /api/admin/* (server-enforced). Case-insensitive.
# ADMIN_EMAILS="somejeevam@gmail.com"

# --- SEO & analytics (optional) ---
# Canonical URLs, sitemap, and Open Graph use NEXT_PUBLIC_APP_URL (set above).
# Google Analytics 4 — measurement ID from GA4 Admin → Data streams (format G-XXXXXXXXXX).
# Default in code is G-1QVVVRK9NH; set one of these to override (e.g. staging) or leave unset.
# GA_MEASUREMENT_ID="G-XXXXXXXXXX"
# NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"
# On Vercel: set at least one of the above, then Redeploy. Verify with View Source on www — search for googletagmanager.com.
# Google Search Console HTML tag verification (content value from the meta tag Google gives you).
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION="..."

# Server-only secrets (do NOT use NEXT_PUBLIC_*): OPENAI_API_KEY, AUTH_SECRET, DATABASE_URL, DIRECT_URL,
# STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET, RESEND_API_KEY, TURNSTILE_SECRET_KEY, UPSTASH_* , CRON_SECRET, GOOGLE_CLIENT_SECRET, ADMIN_EMAILS.
# Transactional From is not an env var; edit lib/transactional-email-from.ts if it must change.
# See lib/security-env.ts (SERVER_ONLY_ENV_HINTS) when adding new secrets.
