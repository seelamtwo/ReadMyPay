generator client {
  provider = "prisma-client-js"
}

// DATABASE_URL = transaction pooler (6543). DIRECT_URL = session pooler on same *.pooler.supabase.com host (5432), not db.*.supabase.co — see .env.example.
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                          String               @id @default(cuid())
  email                       String               @unique
  emailVerified               DateTime?
  /// When true, dashboard/APIs stay blocked until emailVerified is set (new credential signups only).
  requiresEmailVerification   Boolean              @default(false)
  hashedPassword              String?
  name                        String?
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt
  subscription         Subscription?
  accounts             Account[]
  sessions             Session[]
  passwordResetTokens  PasswordResetToken[]
  documentUsageLogs    DocumentUsageLog[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Subscription {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCustomerId     String   @unique
  stripeSubscriptionId String?
  stripePriceId        String?
  tier                 Tier     @default(FREE)
  docsUsedThisMonth    Int      @default(0)
  /// One-off $0.99 purchases; consumed after the free monthly doc on FREE tier.
  prepaidDocCredits    Int      @default(0)
  billingPeriodStart   DateTime @default(now())
  /// Set when the user cancels in-app (cancel at period end). Cleared if they resume via Stripe.
  cancelAtPeriodEndAt DateTime?
  cancelReasonCategory  String?  @db.VarChar(64)
  cancelReasonDetail    String?  @db.Text
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

/// Idempotent record so prepaid credit is applied once per Checkout Session (webhook + client sync).
model StripePrepaidFulfillment {
  checkoutSessionId String   @id
  userId            String
  createdAt         DateTime @default(now())
}

/// One row per billable document processed (explain or spending summary).
model DocumentUsageLog {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentName String            @db.VarChar(512)
  flow         DocumentUsageFlow
  createdAt    DateTime          @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

enum DocumentUsageFlow {
  EXPLAIN
  SPENDING
}

/// Admin-only mutations (refunds, usage); inspect for compliance.
model AdminAuditLog {
  id             String   @id @default(cuid())
  adminUserId    String
  targetUserId   String?
  action         String   @db.VarChar(64)
  payload        Json
  stripeRefundId String?  @db.VarChar(128)
  createdAt      DateTime @default(now())

  @@index([adminUserId, createdAt(sort: Desc)])
  @@index([targetUserId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  access_token      String? @db.Text
  refresh_token     String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Tier {
  FREE
  PERSONAL
}
